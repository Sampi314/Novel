{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(npm run:*)",
      "Bash(npm install:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(chmod:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/sampi_wu/Downloads/Claude Code/.claude/hooks/protect-files.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/sampi_wu/Downloads/Claude Code/.claude/hooks/check-build.sh\"",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "\"/Users/sampi_wu/Downloads/Claude Code/.claude/hooks/validate-data.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Code cần bạn xem\" with title \"Cố Nguyên Giới Map\"' 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/Users/sampi_wu/.local/bin/ccstatusline"
  },
  "enabledPlugins": {}
}
